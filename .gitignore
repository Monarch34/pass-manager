# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
**/.gradle/
build/

# Do not commit: Gradle 8.8+ `updateDaemonJvm` output conflicts with org.gradle.java.home / IDE JDK.
gradle/gradle-daemon-jvm.properties

# Local configuration file (SDK path — machine-specific)
local.properties

# Desktop: full JDK path for packageMsi (copy from desktop/gradle.properties.example)
desktop/gradle.properties
# Desktop: isolated Gradle home used only by package-msi.cmd (avoids ~/.gradle overriding java.home)
desktop/.gradle-packaging-userhome/

# Environment and secrets (never commit)
.env
.env.*
*.env
secrets.properties
**/secrets.properties
keystore.properties
*.pem
*.p12
# Play / CI service accounts (keep google-services.json if you add Firebase — often committed)
serviceAccount*.json

# Android Studio
*.iml
.idea/
*.ipr
*.iws

# Kotlin
.kotlin/

# External native build
.externalNativeBuild/
.cxx/

# NDK
obj/

# Captures build configuration
captures/

# Keystore files
*.jks
*.keystore

# Proguard
proguard/

# OS files
.DS_Store
Thumbs.db

# Android / JVM heap dumps (never commit)
*.hprof

# Temporary files
*.log
*.tmp
*.swp
*~

# Editor / IDE config (machine-specific, not part of the project)
.cursor/
.vscode/
.windsurf/

# Local agent/editor runtime artifacts
build_output.txt

# Stray Gradle downloads (use wrapper only)
gradle-temp.zip
gradle-*.zip
gradle-temp/
gradle-8.*/
gradle-9.*/

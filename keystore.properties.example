# Copy to keystore.properties in the repo root (gitignored) to sign release APKs with your own key.
# Paths are relative to the repository root unless you use an absolute path.
#
# Create a keystore once (example):
#   keytool -genkey -v -keystore release.keystore -alias passmanager -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile=release.keystore
# storePassword=your_store_password
# keyAlias=passmanager
# keyPassword=your_key_password

storeFile=release.keystore
storePassword=
keyAlias=
keyPassword=

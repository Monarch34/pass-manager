<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Cleartext is blocked globally. LAN desktop pairing uses cleartext HTTP
        but the DesktopPairingClient enforces a private-IP-only check before
        connecting, and all payloads are encrypted at the application layer
        (ephemeral ECDH + AES-256-GCM). Ktor CIO bypasses NetworkSecurityPolicy
        so this config acts as defence-in-depth for any other HTTP code.
    -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>

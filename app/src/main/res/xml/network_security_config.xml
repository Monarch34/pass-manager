<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Cleartext HTTP is permitted for LAN desktop pairing. All payloads are
        encrypted at the application layer (ephemeral ECDH + AES-256-GCM),
        so TLS is not required. The phone connects to a desktop server on
        the local network — no cloud traffic.
    -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
